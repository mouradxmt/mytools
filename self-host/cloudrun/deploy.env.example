# Copy to deploy.env and fill in. deploy.env is gitignored.
GCP_PROJECT=                 # your GCP project id, e.g. mytools-470212
REGION=europe-southwest1     # Madrid — closest to Morocco (~20-40ms). Paris=europe-west9 also good.
SERVICE=mytools              # Cloud Run service name

# Hosted Supabase (free tier) → Settings → API
SUPABASE_URL=           # https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=      # client key — use the publishable key (sb_publishable_...);
                        # legacy anon JWT also works. NOT the secret/service_role key.

# Optional: map a custom domain after first deploy (leave blank to use the *.run.app URL)
CUSTOM_DOMAIN=
