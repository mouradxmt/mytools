# Copy to deploy.env and fill in. deploy.env is gitignored.
# --- SSH / instance ---
SSH_HOST=          # public IP of the OCI instance, e.g. 130.61.x.x
SSH_USER=opc       # Oracle Linux default user
SSH_KEY=~/.ssh/id_ed25519

# --- Public address ---
DOMAIN=            # e.g. tools.example.com  (DNS A record must point at SSH_HOST)
TLS_EMAIL=         # email for Let's Encrypt expiry notices

# --- Hosted Supabase (free tier) ---
SUPABASE_URL=          # https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=     # the anon/public key from Supabase → Settings → API
